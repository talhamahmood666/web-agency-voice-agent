{
  "name": "web-agency-voice-agent",
  "version": "1.0.0",
  "description": "Voice agent for web agency customer interactions",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "scrape": "ts-node src/scraper/runner.ts",
    "import-leads": "ts-node src/scraper/import.ts",
    "generate-demos": "ts-node src/demos/runner.ts",
    "deploy-demos": "vercel public/demos --prod --yes"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "ts-node": "^10.9.2",
    "twilio": "^6.0.2",
    "typescript": "^5.5.4",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "nodemon": "^3.1.4"
  }
}
